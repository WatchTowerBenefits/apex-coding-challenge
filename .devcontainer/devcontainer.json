{
  "name": "Rails + Vue",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/ruby:1": {
      "version": "3.3.3"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y libsqlite3-dev && bundle install && cd frontend && npm install",
  "postCreateCommand": "bin/rails db:setup",
  "postStartCommand": "bin/rails db:migrate",
  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": { "label": "Rails API" },
    "5173": { "label": "Vue Dev Server" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "shopify.ruby-lsp",
        "Vue.volar"
      ]
    }
  }
}
