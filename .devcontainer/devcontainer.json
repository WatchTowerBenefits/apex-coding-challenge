{
  "name": "Rails + Vue",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/ruby:1": {
      "version": "3.3.3"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends libsqlite3-dev libvips shared-mime-info libyaml-dev redis-server",
  "postCreateCommand": "bundle install && cd frontend && npm install && cd .. && bin/rails db:setup",
  "postStartCommand": "sudo service redis-server start || true",
  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": {
      "label": "Rails API",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vue Dev Server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "shopify.ruby-lsp",
        "Vue.volar",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[ruby]": {
          "editor.defaultFormatter": "Shopify.ruby-lsp"
        }
      }
    }
  }
}
