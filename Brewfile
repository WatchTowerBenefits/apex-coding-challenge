# Database
brew "sqlite"

# Background job processing (required by Sidekiq)
brew "redis"

# JavaScript runtime & package manager (Vue.js frontend)
brew "node"

# Process manager for Procfile.dev
brew "overmind"

# Shared MIME info (used by Marcel/Active Storage for MIME type detection)
brew "shared-mime-info"

# LibYAML (native YAML parsing, used by Psych gem)
brew "libyaml"
